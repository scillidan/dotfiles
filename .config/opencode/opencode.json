{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "lkeap/glm-5.1",
      "options": {},
      "permission": {
        "bash": "allow",
        "edit": "allow"
      },
      "tools": {
        "bash": true,
        "edit": true,
        "write": true
      }
    },
    "plan": {
      "mode": "primary",
      "model": "lkeap/glm-5.1",
      "options": {},
      "permission": {
        "bash": "deny",
        "edit": "deny"
      },
      "tools": {
        "bash": false,
        "edit": false,
        "write": false
      }
    }
  },
  "autoupdate": false,
  "enabled_providers": [
    "deepseek",
    "lkeap",
    "aiping",
    "openai",
    "llama-swap"
  ],
  "mcp": {
    "fff": {
      "command": [
        "fff-mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "gimp-mcp": {
      "command": [
        "uv",
        "run",
        "--directory",
        "C:/Users/User/Local/Srv/gimp-mcp",
        "gimp_mcp_server.py"
      ],
      "enabled": false,
      "type": "local"
    },
    "godot-mcp": {
      "type": "remote",
      "url": "http://localhost:9080/mcp"
    }
  },
  "permission": {
    "webfetch": "allow",
    "websearch": "allow"
  },
  "plugin": [
    "@mohak34/opencode-notifier@latest"
  ],
  "provider": {
    "aiping": {
      "models": {
        "GLM-5": {
          "name": "GLM 5"
        }
      },
      "name": "AIPing",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:AIPING_API_KEY}",
        "baseURL": "https://aiping.cn/api/v1"
      }
    },
    "deepseek": {
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        }
      },
      "name": "DeepSeek",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:DEEPSEEK_API_KEY}",
        "baseURL": "https://api.deepseek.com"
      }
    },
    "lkeap": {
      "models": {
        "glm-5-turbo": {
          "name": "GLM 5 Turbo",
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        },
        "glm-5.1": {
          "name": "GLM 5.1",
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        }
      },
      "name": "LKEAP",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:TENCENT_LKEAP_API_KEY}",
        "baseURL": "https://api.lkeap.cloud.tencent.com/plan/v3"
      }
    },
    "llama-swap": {
      "models": {
        "gemma-3-12b-it": {
          "name": "Gemma 3 12B IT (Q5_K_M)"
        },
        "gemma-3-4b-it-qat": {
          "name": "Gemma 3 4B IT (Q4_K_M)"
        },
        "mistral-7b-instruct-v0.3": {
          "name": "Mistral 7B Instruct v0.3 (Q5_K_M)"
        },
        "qwen3-14b": {
          "name": "Qwen3-14B (Q4_K_M)"
        }
      },
      "name": "llama-swap",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:8010/v1"
      }
    },
    "openai": {
      "models": {
        "gpt-5.5": {
          "name": "GPT 5.5"
        }
      },
      "options": {
        "apikey": "{env:CHATANYWHERE_API_KEY}",
        "baseURL": "https://api.chatanywhere.tech/v1"
      }
    }
  },
  "share": "disabled",
  "shell": "cmd",
  "skills": {
    "paths": [
      "~/.agents/personal-skills"
    ]
  }
}
