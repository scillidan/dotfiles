{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@mohak34/opencode-notifier",
    // "@zenobius/opencode-skillful"
  ],
  "autoupdate": false,
  "share": "disabled",
  "enabled_providers": [
    "ollama",
    "aiping"
  ],
  "disabled_providers": [
    "openai"
  ],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "ministral-3:8b": {
          "name": "Ministral3 8B"
        },
        "mistral:7b-instruct": {
          "name": "Mistral 7B Instruct"
        },
        "qwen3.5:9b": {
          "name": "Qwen3.5 9B"
        }
      },
    },
    "aiping": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "AIPing",
      "options": {
        "baseURL": "https://aiping.cn/api/v1",
        "apiKey": "{env:AIPING_API_KEY}"
      },
      "models": {
        "MiniMax-M2.7": {
          "name": "MiniMax M2.7"
        },
        "GLM-5": {
          "name": "GLM 5"
        },
        "Kimi-K2.5": {
          "name": "Kimi K2.5"
        }
      }
    },
    "openai": {
      "options": {
        "apikey": "{env:OPENAI_API_KEY}",
        "baseURL": "{env:OPENAI_API_BASE}"
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4"
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 mini"
        }
      }
    }
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "model": "aiping/GLM-5",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "build": {
      "mode": "primary",
      "model": "aiping/GLM-5",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    }
  }
}
