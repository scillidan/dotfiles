{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "share": "disabled",
  "permission": {
    "websearch": "allow",
    "webfetch": "allow"
  },
  "plugin": [
  	"@mohak34/opencode-notifier@latest"
  ],
  "enabled_providers": [
    "lkeap",
    "aiping",
    "openai",
    "ollama"
  ],
  "provider": {
    "lkeap": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LKEAP",
      "options": {
        "apiKey": "{env:TENCENT_LKEAP_API_KEY}",
        "baseURL": "https://api.lkeap.cloud.tencent.com/plan/v3"
      },
      "models": {
		    "glm-5": {
		      "name": "GLM-5",
		      "options": {
		        "thinking": {
		          "type": "enabled",
		          "budgetTokens": 8192
		        }
		      },
		      "limit": {
		        "context": 200000,
		        "output": 128000
		      }
		    }
      }
    },
    "aiping": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "AIPing",
      "options": {
        "apiKey": "{env:AIPING_API_KEY}",
        "baseURL": "https://aiping.cn/api/v1"
      },
      "models": {
        "GLM-5": {
          "name": "GLM 5"
        }
      }
    },
    // ChatAnywhere
    "openai": {
      "options": {
        "apikey": "{env:CHATANYWHERE_API_KEY}",
        "baseURL": "https://api.chatanywhere.tech/v1"
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT 5.5"
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "mistral:7b-instruct": {
          "name": "Mistral 7B Instruct"
        }
      }
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "model": "lkeap/glm-5",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "options": {},
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "plan": {
      "mode": "primary",
      "model": "lkeap/glm-5",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      },
      "options": {},
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    }
  },
  "mcp": {
    "fff": {
      "type": "local",
      "command": ["fff-mcp"],
      "enabled": true
    },
    "godot-mcp": {
      "type": "remote",
      "url": "http://localhost:9080/mcp"
    }
  },
  "shell": "cmd"
}
