{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "deepseek/deepseek-v4-flash",
      "options": {},
      "permission": {
        "bash": "allow",
        "edit": "allow"
      },
      "tools": {
        "bash": true,
        "edit": true,
        "write": true
      }
    },
    "plan": {
      "mode": "primary",
      "model": "deepseek/deepseek-v4-flash",
      "options": {},
      "permission": {
        "bash": "deny",
        "edit": "deny"
      },
      "tools": {
        "bash": false,
        "edit": false,
        "write": false
      }
    }
  },
  "autoupdate": false,
  "enabled_providers": [
    "deepseek",
    "codebuddy",
    // "lkeap",
    "aiping",
    "openai"
  ],
  "mcp": {
    "fff": {
      "command": [
        "fff-mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "gimp-mcp": {
      "command": [
        "uv",
        "run",
        "--directory",
        "C:/Users/User/Local/Srv/gimp-mcp",
        "gimp_mcp_server.py"
      ],
      "enabled": false,
      "type": "local"
    },
    "godot-mcp": {
      "type": "remote",
      "url": "http://localhost:9080/mcp"
    }
  },
  "permission": {
    "webfetch": "allow",
    "websearch": "allow"
  },
  "provider": {
    "deepseek": {
      "models": {
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        }
      },
      "name": "DeepSeek",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:DEEPSEEK_API_KEY}",
        "baseURL": "https://api.deepseek.com"
      }
    },
    "codebuddy": {
      "models": {
        "glm-5.2": {
          "name": "GLM-5.2",
          "contextLength": 200000,
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        },
        "glm-5.0-turbo": {
          "name": "GLM-5.0-Turbo",
          "contextLength": 200000,
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        },
        "hy3-preview-agent": {
          "name": "Hy3-preview",
          "contextLength": 192000,
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        }
      },
      "name": "CodeBuddy",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:CODEBUDDY_API_KEY}",
        "baseURL": "https://copilot.tencent.com/v2"
      }
    },
    "lkeap": {
      "models": {
        "glm-5.2": {
          "name": "GLM 5.2",
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        },
        "glm-5-turbo": {
          "name": "GLM 5 Turbo",
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        }
      },
      "name": "LKEAP",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:TENCENT_LKEAP_API_KEY}",
        "baseURL": "https://api.lkeap.cloud.tencent.com/plan/v3"
      }
    },
    "aiping": {
      "models": {
        "GLM-5": {
          "name": "GLM 5"
        }
      },
      "name": "AIPing",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:AIPING_API_KEY}",
        "baseURL": "https://aiping.cn/api/v1"
      }
    },
    "openai": {
      "models": {
        "gpt-5.5": {
          "name": "GPT 5.5"
        }
      },
      "options": {
        "apikey": "{env:CHATANYWHERE_API_KEY}",
        "baseURL": "https://api.chatanywhere.tech/v1"
      }
    }
  },
  "share": "disabled",
  "shell": "cmd",
  "skills": {
    "paths": [
      "~/.agents/personal-skills"
    ]
  },
  "compaction": {
    "auto": false,
    "prune": false
  }
}
