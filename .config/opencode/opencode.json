{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "deepseek/deepseek-v4-flash",
      "options": {},
      "permission": {
        "bash": "allow",
        "edit": "allow"
      },
      "tools": {
        "bash": true,
        "edit": true,
        "write": true
      }
    },
    "plan": {
      "mode": "primary",
      "model": "deepseek/deepseek-v4-flash",
      "options": {},
      "permission": {
        "bash": "deny",
        "edit": "deny"
      },
      "tools": {
        "bash": false,
        "edit": false,
        "write": false
      }
    }
  },
  "autoupdate": false,
  "compaction": {
    "auto": false,
    "prune": false
  },
  "enabled_providers": [
    "deepseek",
    "moonshot"
  ],
  "formatter": true,
  "lsp": true,
  "mcp": {
    "agnix": {
      "command": [
        "agnix-mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "cq": {
      "command": [
        "cq",
        "mcp"
      ],
      "type": "local"
    },
    "fff": {
      "command": [
        "fff-mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "gimp-mcp": {
      "command": [
        "uv",
        "run",
        "gimp_mcp_server.py"
      ],
      "cwd": "C:/Users/User/Local/Srv/gimp-mcp",
      "enabled": false,
      "type": "local"
    },
    "godot-mcp": {
      "enabled": false,
      "type": "remote",
      "url": "http://localhost:9080/mcp"
    }
  },
  "permission": {
    "webfetch": "allow",
    "websearch": "allow"
  },
  "provider": {
    "moonshot": {
      "models": {
        "k3": {
          "name": "Kimi K3",
          "options": {
            "thinking": { "type": "enabled", "effort": "max" }
          }
        },
        "kimi-for-coding-highspeed": {
          "name": "Kimi K2.7 Code (HighSpeed)",
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        }
      },
      "name": "Moonshot",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:MOONSHOT_API_KEY}",
        "baseURL": "https://api.kimi.com/coding/v1"
      }
    },
    "deepseek": {
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        }
      },
      "name": "DeepSeek",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:DEEPSEEK_API_KEY}",
        "baseURL": "https://api.deepseek.com"
      }
    }
  },
  "share": "disabled",
  "shell": "cmd",
  "skills": {
    "paths": [
      "~/.agents/personal-skills"
    ]
  }
}
