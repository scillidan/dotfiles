{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "codebuddy/deepseek-v4-flash",
      "options": {},
      "permission": {
        "bash": "allow",
        "edit": "allow"
      },
      "tools": {
        "bash": true,
        "edit": true,
        "write": true
      }
    },
    "plan": {
      "mode": "primary",
      "model": "codebuddy/deepseek-v4-flash",
      "options": {},
      "permission": {
        "bash": "deny",
        "edit": "deny"
      },
      "tools": {
        "bash": false,
        "edit": false,
        "write": false
      }
    }
  },
  "autoupdate": false,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "formatter": true,
  "enabled_providers": [
    "deepseek",
    "codebuddy"
  ],
  "lsp": true,
  "mcp": {
    "aginx": {
      "command": ["aginx-mcp"],
      "enabled": true,
      "type": "local"
    },
    "fff": {
      "command": ["fff-mcp"],
      "enabled": true,
      "type": "local"
    },
    "gimp-mcp": {
      "command": ["uv", "run", "gimp_mcp_server.py"],
      "cwd": "C:/Users/User/Local/Srv/gimp-mcp",
      "enabled": false,
      "type": "local"
    },
    "godot-mcp": {
      "enabled": false,
      "type": "remote",
      "url": "http://localhost:9080/mcp"
    }
  },
  "permission": {
    "webfetch": "allow",
    "websearch": "allow"
  },
  "provider": {
    "deepseek": {
      "models": {
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        }
      },
      "name": "DeepSeek",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:DEEPSEEK_API_KEY}",
        "baseURL": "https://api.deepseek.com"
      }
    },
    "codebuddy": {
      "models": {
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "contextLength": 200000,
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "contextLength": 200000,
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        }
      },
      "name": "CodeBuddy",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:CODEBUDDY_API_KEY}",
        "baseURL": "https://copilot.tencent.com/v2"
      }
    }
  },
  "share": "disabled",
  "shell": "cmd",
  "skills": {
    "paths": [
      "~/.agents/personal-skills"
    ]
  },
  "compaction": {
    "auto": false,
    "prune": false
  }
}
