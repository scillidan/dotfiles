{
  "defaultProvider": "deepseek",
  "defaultModel": "deepseek-v4-flash",
  "defaultThinkingLevel": "medium",
  "theme": "dark",
  "packages": [
    "npm:@cortexkit/pi-magic-context",
    "npm:@ff-labs/pi-fff",
    "npm:pi-autoresearch",
    "npm:pi-lens",
    "git:github.com/DietrichGebert/ponytail"
  ],
  "skills": [
    "~/.agents/skills",
    "~/.agents/personal-skills",
    "transcribe"
  ],
  "extensions": [],
  "enableSkillCommands": true,
  "compaction": {
    "enabled": true,
    "reserveTokens": 32768,
    "keepRecentTokens": 40000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "provider": {
      "timeoutMs": 600000,
      "maxRetries": 0,
      "maxRetryDelayMs": 60000
    }
  },
  "lastChangelogVersion": "0.80.2"
}